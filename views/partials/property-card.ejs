<!-- Reusable Property Card -->
<!-- File: views/partials/property-card.ejs -->

<div class="property-card h-100 d-flex flex-column" data-hotel-id="<%= hotel._id %>" data-price="<%= hotel.price %>" data-location="<%= hotel.location %>" data-name="<%= hotel.name %>">
  
  <!-- Large Image Container -->
  <div class="card-img-container position-relative overflow-hidden">
    <!-- AI badge -->
    <%- include('ai-badge', { hotel: hotel }) %>
    
    <!-- Wishlist Button -->
    <button class="wishlist-btn" data-hotel-id="<%= hotel._id %>" aria-label="Add to Wishlist">
      <i class="fa-regular fa-heart"></i>
    </button>
    
    <img src="<%= hotel.image %>" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=80';" loading="lazy" alt="<%= hotel.name %>" class="w-100 h-100 object-fit-cover">
  </div>
  
  <!-- Card Content -->
  <div class="card-body-content p-3 d-flex flex-column flex-grow-1 justify-content-between">
    <div>
      <div class="d-flex align-items-center justify-content-between mb-2">
        <h5 class="fw-bold text-dark mb-0 text-truncate" style="max-width: 80%;"><%= hotel.name %></h5>
        <span class="card-rating text-dark fw-bold small d-flex align-items-center gap-1">
          <i class="fa-solid fa-star text-warning"></i> 4.8
        </span>
      </div>
      
      <p class="text-muted small mb-2 d-flex align-items-center gap-1">
        <i class="fa-solid fa-location-dot text-danger small"></i> <%= hotel.location %>
      </p>
      
      <p class="small text-muted line-clamp-2 mb-3" style="font-size: 0.85rem; min-height: 2.6rem;">
        <%= hotel.description %>
      </p>
      
      <!-- AI Insight Section -->
      <div class="ai-insight-box p-2.5 mb-3">
        <span class="ai-insight-title d-block fw-bold mb-1">
          <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Yatra Sathi Recommendation
        </span>
        <p class="ai-insight-text mb-0">
          <%- include('ai-badge', { hotel: hotel, showOnlyText: true }) %>
        </p>
      </div>
    </div>
    
    <!-- Bottom Price & CTA Button -->
    <div class="d-flex align-items-center justify-content-between pt-3 border-top mt-auto">
      <span class="card-price fw-bold text-dark fs-5">
        ₹<%= hotel.price.toLocaleString("en-IN") %> <span class="fs-6 text-muted fw-normal">/ night</span>
      </span>
      <a href="/hotels/<%= hotel._id %>" class="btn btn-outline-dark fw-bold rounded-pill px-3 py-1.5" style="font-size: 0.8rem;">
        View Details
      </a>
    </div>
  </div>
  
</div>
