<!-- Sticky Transparent Navbar with Theme Toggle -->
<nav class="navbar navbar-expand-lg fixed-top shadow-sm">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <i class="fa-solid fa-paper-plane text-warning"></i> YatraStay
    </a>

    <button 
      class="navbar-toggler border-0 shadow-none" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#nav" 
      aria-controls="nav" 
      aria-expanded="false" 
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div id="nav" class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto align-items-center gap-2 mt-3 mt-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="/ai-assistant">
            <i class="fa-solid fa-wand-magic-sparkles text-warning me-1"></i> Yatra Sathi
          </a>
        </li>
        
        <% if (!user) { %>
          <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
          <li class="nav-item">
            <a class="btn btn-warning px-4 rounded-pill fw-bold text-dark ms-lg-2" href="/signup">
              Sign Up
            </a>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/booking/my-bookings">My Bookings</a></li>
          <% if (user.role === "admin") { %>
            <li class="nav-item"><a class="nav-link" href="/admin/add-hotel">Add Hotel</a></li>
          <% } %>
          <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
        <% } %>

        <!-- Theme Toggle Switch -->
        <li class="nav-item ms-lg-2">
          <button id="themeToggleBtn" class="theme-toggle-btn d-flex align-items-center justify-content-center" aria-label="Toggle Dark Mode">
            <i class="fa-solid fa-moon"></i>
          </button>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- Prevent fixed navbar from overlapping elements -->
<div style="height: 80px;"></div>
