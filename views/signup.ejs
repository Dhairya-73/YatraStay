<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup - YatraStay</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="/css/theme.css">
  
  <style>
    .auth-bg {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-bg-base);
    }
    
    .auth-card {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
      padding: 40px;
      width: 100%;
      max-width: 440px;
      box-shadow: var(--shadow-lg);
    }
    
    .auth-input-group {
      position: relative;
      margin-bottom: 20px;
    }
    
    .auth-input {
      background: var(--color-bg-base);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-input);
      padding: 12px 16px 12px 46px;
      font-size: 0.95rem;
      color: var(--color-text-main);
      width: 100%;
      outline: none;
      transition: all var(--speed-fast) var(--easing-premium);
    }
    
    .auth-input:focus {
      border-color: var(--color-accent-gold);
      box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
      background: var(--color-white);
    }
    
    .auth-input-icon {
      position: absolute;
      left: 16px;
      top: 15px;
      color: var(--color-text-muted);
      font-size: 1.05rem;
    }
    
    .password-toggle {
      position: absolute;
      right: 16px;
      top: 15px;
      color: var(--color-text-muted);
      font-size: 1.05rem;
      cursor: pointer;
      background: transparent;
      border: none;
      padding: 0;
    }
    
    .password-toggle:hover {
      color: var(--color-text-main);
    }

    .text-warning-dark {
      color: #b45309 !important;
    }
  </style>
</head>
<body>

<%- include("partials/navbar") %>

<div class="auth-bg py-5 px-3">
  <div class="auth-card">
    
    <div class="text-center mb-4">
      <i class="fa-solid fa-user-plus text-warning fs-1 mb-2"></i>
      <h3 class="fw-bold text-dark mb-1" style="font-family: 'Outfit', sans-serif;">Create Account</h3>
      <p class="text-muted small">Sign up to unlock verified reviews and travel planning tools</p>
    </div>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="alert alert-danger border-0 p-3 mb-4 small d-flex align-items-center gap-2" style="border-radius: 8px;">
        <i class="fa-solid fa-circle-exclamation fs-5"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form method="POST">
      <!-- Name Input -->
      <div class="auth-input-group">
        <i class="fa-solid fa-user auth-input-icon"></i>
        <input class="auth-input" name="name" type="text" placeholder="Full Name" required autocomplete="name">
      </div>

      <!-- Email Input -->
      <div class="auth-input-group">
        <i class="fa-solid fa-envelope auth-input-icon"></i>
        <input class="auth-input" name="email" type="email" placeholder="Email Address" required autocomplete="email">
      </div>

      <!-- Password Input -->
      <div class="auth-input-group">
        <i class="fa-solid fa-key auth-input-icon"></i>
        <input class="auth-input" name="password" type="password" id="passwordInput" placeholder="Create Password" required autocomplete="new-password">
        <button type="button" class="password-toggle" id="passwordToggleBtn" aria-label="Toggle Password Visibility">
          <i class="fa-solid fa-eye"></i>
        </button>
      </div>

      <!-- T&C Helper Checkbox -->
      <div class="form-check mb-4" style="font-size: 0.85rem;">
        <input class="form-check-input shadow-none" type="checkbox" id="termsCheck" required>
        <label class="form-check-label text-muted" for="termsCheck">
          I agree to the <a href="#" class="text-decoration-none fw-semibold text-warning-dark">Terms of Service</a> &amp; <a href="#" class="text-decoration-none fw-semibold text-warning-dark">Privacy Policy</a>
        </label>
      </div>

      <!-- Signup Submit Button -->
      <button class="btn btn-warning w-100 fw-bold text-dark py-2.5 rounded-pill shadow-sm" style="font-size: 0.95rem;">
        Create Account
      </button>
    </form>

    <div class="text-center mt-4 pt-3 border-top" style="font-size: 0.88rem;">
      <span class="text-muted">Already have an account?</span>
      <a href="/login" class="text-decoration-none fw-bold text-warning-dark ms-1">Log In</a>
    </div>

  </div>
</div>

<%- include("partials/footer") %>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const passwordInput = document.getElementById("passwordInput");
    const toggleBtn = document.getElementById("passwordToggleBtn");
    
    if (toggleBtn && passwordInput) {
      toggleBtn.addEventListener("click", () => {
        const type = passwordInput.getAttribute("type");
        if (type === "password") {
          passwordInput.setAttribute("type", "text");
          toggleBtn.innerHTML = '<i class="fa-solid fa-eye-slash"></i>';
        } else {
          passwordInput.setAttribute("type", "password");
          toggleBtn.innerHTML = '<i class="fa-solid fa-eye"></i>';
        }
      });
    }
  });
</script>
</body>
</html>
