<% layout("./layouts/Boilerplate.ejs") %>
    <div class="row" >
        <div class="col-8 offset-2">
            <h1 class="offset-3 mt-2">SignUp on YatraStay</h1><br>
            <form method="POST" action="/signup" class="needs-validation" novalidate>
                <div class="mb-3">
             <label for="username">Username</label>
        <input name="username" class="form-control" type="text" id="username" required>
        <div class="invalid-feedback">Title can't be empty</div>
    </div>

     <div class="mb-3">
             <label for="email">Email</label>
        <input name="email" class="form-control" type="email" id="email" required>
        <div class="invalid-feedback">Title can't be empty</div>
    </div>

     <div class="mb-3">
             <label for="password">Password</label>
        <input name="password" class="form-control" type="password" id="password" required>
        <div class="invalid-feedback">Title can't be empty</div>
    </div>

         <button type="submit" class="btn btn-success">SignUp</button>
        <br><br><br>

        </form>
            </div>
        </div>
        
