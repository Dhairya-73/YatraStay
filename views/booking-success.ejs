<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Booking Confirmed! - YatraStay</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="/css/theme.css">
  
  <style>
    /* Animated Draw Success Checkmark */
    .success-card {
      background: var(--color-white);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
      padding: 40px;
      box-shadow: var(--shadow-lg);
      max-width: 600px;
      margin: 40px auto;
      text-align: center;
    }
    
    .checkmark-svg {
      width: 72px;
      height: 72px;
      display: block;
      margin: 0 auto 24px;
    }
    
    .checkmark-circle {
      stroke-dasharray: 166;
      stroke-dashoffset: 166;
      stroke-width: 4;
      stroke-miterlimit: 10;
      stroke: #22c55e; /* Tailwind Green-500 */
      fill: none;
      animation: stroke 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .checkmark-check {
      transform-origin: 50% 50%;
      stroke-dasharray: 48;
      stroke-dashoffset: 48;
      stroke: #22c55e;
      stroke-width: 5;
      stroke-linecap: round;
      fill: none;
      animation: stroke 0.3s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    }
    
    @keyframes stroke {
      100% {
        stroke-dashoffset: 0;
      }
    }
    
    .receipt-container {
      background: #f8fafc;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      padding: 20px;
      text-align: left;
      margin-bottom: 30px;
    }
    
    [data-theme="dark"] .receipt-container {
      background: rgba(15, 23, 42, 0.2);
    }
    
    .receipt-meta-row {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px dashed var(--color-border);
      padding: 10px 0;
      font-size: 0.88rem;
    }
    
    .receipt-meta-row:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
    
    .receipt-meta-row:first-child {
      padding-top: 0;
    }
  </style>
</head>
<body>

<%- include("partials/navbar") %>

<div class="container py-5 container-mobile-padding" style="min-height: 80vh;">
  
  <div class="success-card">
    
    <!-- Custom Animated Checkmark -->
    <svg class="checkmark-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
      <circle class="checkmark-circle" cx="26" cy="26" r="25" />
      <path class="checkmark-check" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
    </svg>

    <h2 class="fw-bold mb-2 text-dark" style="font-family: 'Outfit', sans-serif;">Booking Confirmed!</h2>
    <p class="text-muted small mb-4">Your accommodation reservation has been successfully completed and paid.</p>

    <!-- Receipt Meta Container -->
    <div class="receipt-container shadow-sm">
      <div class="receipt-meta-row">
        <span class="text-muted fw-medium">Confirmation Code</span>
        <%
          // Generate a premium random verification code dynamically
          const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
          let confCode = 'YATRA-';
          for (let i = 0; i < 6; i++) {
            confCode += chars.charAt(Math.floor(Math.random() * chars.length));
          }
        %>
        <span class="text-dark fw-bold" style="letter-spacing: 0.5px;"><%= confCode %></span>
      </div>
      
      <div class="receipt-meta-row">
        <span class="text-muted fw-medium">Payment Status</span>
        <span class="badge bg-success-subtle text-success px-2.5 py-1 rounded fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.5px;">Paid</span>
      </div>
      
      <div class="receipt-meta-row">
        <span class="text-muted fw-medium">Booking Channel</span>
        <span class="text-dark fw-bold">YatraStay Web Gateway</span>
      </div>

      <div class="receipt-meta-row">
        <span class="text-muted fw-medium">Transaction Date</span>
        <%
          const dateOpts = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
          const nowFormatted = new Date().toLocaleDateString("en-IN", dateOpts);
        %>
        <span class="text-dark fw-bold"><%= nowFormatted %></span>
      </div>
    </div>

    <!-- CTA Redirection Actions -->
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
      <a href="/booking/my-bookings" class="btn btn-warning text-dark fw-bold px-4 py-2.5 rounded-pill shadow-sm" style="font-size:0.9rem;">
        <i class="fa-solid fa-list-ul me-1.5"></i> View My Bookings
      </a>
      <a href="/" class="btn btn-outline-dark fw-bold px-4 py-2.5 rounded-pill" style="font-size:0.9rem;">
        <i class="fa-solid fa-house me-1.5"></i> Return Home
      </a>
    </div>

  </div>

</div>

<%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
