<% layout("./layouts/Boilerplate.ejs") %>
    <div class="row" >
        <div class="col-8 offset-2">
            <h1>Create a New Listing</h1><br>
            <form method="POST" action="/listings" class="needs-validation" novalidate>
                <div class="mb-3">
             <label for="title">Title</label>
        <input name="listing[title]" class="form-control" placeholder="enter title" type="text" id="title" required>
        <div class="invalid-feedback">Title can't be empty</div>
    </div>
        <div class="mb-3">
             <label for="desc">Description</label>
        <textarea name="listing[description]" class="form-control" placeholder="enter description" id="desc" required></textarea>
        <div class="invalid-feedback">Provide short description</div>
    </div>
        <div class="mb-3">
            <label for="image">Image</label>
         <input name="listing[image]" class="form-control" placeholder="enter image link" type="text" id="image" required>
        <div class="invalid-feedback">Provide image link</div>
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price">Price</label>
         <input name="listing[price]" class="form-control" placeholder="enter price" type="number" id="price" required>
            <div class="invalid-feedback">Price should be valid</div>
        </div>
        <div class="mb-3 col-md-8">
 <label for="location">Location</label> 
        <input name="listing[location]" class="form-control" placeholder="enter location" type="text" id="location" required>
        <div class="invalid-feedback">Location should be valid</div>
        </div>
        </div>
        
       <div class="mb-3">
        <label for="country">Country</label>
        <input name="listing[country]" class="form-control" placeholder="enter country" type="text" id="country" required>
        <div class="invalid-feedback">Country should be valid</div>
    </div>
        <button type="submit" class="btn btn-dark add-btn">Add</button>
        <br><br><br>
        </form>
            </div>
        </div>
        
